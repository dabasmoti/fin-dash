# =============================================================================
# fin-dash Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# =============================================================================

# Server port (default: 3001; Cloud Run sets PORT=8080 automatically)
SERVER_PORT=3001

# Frontend origin for CORS (default: http://localhost:5173)
CLIENT_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Bearer token for API authentication. When set, all API endpoints (except
# /api/health) require this token via Authorization header or cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty to disable auth (local development only).
AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Cloud Storage backup (Cloud Run only)
# ---------------------------------------------------------------------------
# GCS bucket name for SQLite database backup/restore.
# Leave empty to disable GCS backup (local development).
GCS_BUCKET=

# ---------------------------------------------------------------------------
# Scheduler (automatic scraping)
# ---------------------------------------------------------------------------
# How often to scrape all banks, in minutes (default: 360 = 4x/day)
# On Cloud Run this is ignored — Cloud Scheduler controls the interval.
SCRAPE_INTERVAL_MINUTES=360

# Enable or disable the automatic scraping scheduler (default: true)
SCHEDULER_ENABLED=true

# ---------------------------------------------------------------------------
# Scraper timeouts and cache
# ---------------------------------------------------------------------------
# Timeout (ms) for a single bank scrape via Puppeteer (default: 120000 = 2 min)
SCRAPER_TIMEOUT_MS=120000

# In-memory cache TTL (ms) for scrape results (default: 300000 = 5 min)
CACHE_TTL_MS=300000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Path to the SQLite database file (default: server/data/fin-dash.db)
# In Docker, this is set to /app/data/fin-dash.db via docker-compose.yml
DB_PATH=

# ---------------------------------------------------------------------------
# Puppeteer / Chromium
# ---------------------------------------------------------------------------
# Path to the Chromium binary used by Puppeteer for headless scraping
# In Docker, this is set to /usr/bin/chromium via docker-compose.yml
# On macOS/Windows, leave empty to use Puppeteer's bundled Chromium
PUPPETEER_EXECUTABLE_PATH=

# ---------------------------------------------------------------------------
# Beinleumi (First International Bank)
# ---------------------------------------------------------------------------
BEINLEUMI_USERNAME=
BEINLEUMI_PASSWORD=

# ---------------------------------------------------------------------------
# Max (credit card)
# ---------------------------------------------------------------------------
MAX_USERNAME=
MAX_PASSWORD=

# ---------------------------------------------------------------------------
# Isracard (credit card)
# ---------------------------------------------------------------------------
ISRACARD_ID=
ISRACARD_CARD6DIGITS=
ISRACARD_PASSWORD=

# ---------------------------------------------------------------------------
# CAL / Visa Cal (credit card)
# ---------------------------------------------------------------------------
VISACAL_USERNAME=
VISACAL_PASSWORD=
